# ---- Bot (required) --------------------------------------------------------
# Token from @BotFather (create a bot with /newbot)
BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Your numeric Telegram user id (ask @userinfobot). Only this user is served.
ALLOWED_USER_ID=123456789

# ---- deploy.sh (only needed for the registry + Portainer deploy) ------------
# Where to push the image; the Portainer stack pulls it from here.
IMAGE=registry.example.com/yt-audio-bot:latest
PORTAINER_URL=https://portainer.example.com:9443
PORTAINER_API_KEY=ptr_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
PORTAINER_ENDPOINT_ID=1
STACK_NAME=yt-audio-bot
# Target platform of your server (default linux/x86_64)
#BUILD_PLATFORM=linux/x86_64
# Optional: if your Portainer uses a self-signed/expired certificate, pin it by
# SHA-256 fingerprint instead of disabling TLS verification:
#   echo | openssl s_client -connect host:9443 2>/dev/null | openssl x509 -outform der | shasum -a 256
#PORTAINER_TLS_FINGERPRINT=
